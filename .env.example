# Database
DATABASE_URL="postgresql://username:password@localhost:5432/danesh?schema=public"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-generate-with-openssl-rand-base64-32"

# OAuth Providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
APPLE_ID=""
APPLE_SECRET=""

# Email (for password reset, notifications)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="noreply@danesh.app"

# Storage (for uploaded content, images)
STORAGE_PROVIDER="local" # local, s3, cloudinary
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""
AWS_REGION=""

# Analytics
NEXT_PUBLIC_GA_ID=""

# AI Services (for adaptive learning)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.4"

# Live classes provider
# Supported values today: jitsi, bigbluebutton, disabled
NEXT_PUBLIC_ENABLE_LIVE_CLASSES="true"
NEXT_PUBLIC_LIVE_CLASS_PROVIDER="jitsi"

# Jitsi / 8x8 JaaS live classes
# App ID is safe to expose to the browser.
NEXT_PUBLIC_JAAS_APP_ID=""
# Optional. Leave empty to auto-use 8x8.vc when NEXT_PUBLIC_JAAS_APP_ID is set.
NEXT_PUBLIC_JITSI_DOMAIN=""
# Optional server-side overrides.
JITSI_JAAS_APP_ID=""
JITSI_JAAS_DOMAIN=""
# Add the API key identifier (kid) from the 8x8 JaaS console.
JITSI_JAAS_KID=""
# Paste the full private key here. Use \n for line breaks if you keep it on one line.
JITSI_JAAS_PRIVATE_KEY=""

# BigBlueButton placeholders for future provider switching
BIGBLUEBUTTON_BASE_URL=""
BIGBLUEBUTTON_SHARED_SECRET=""

# Payment (for Premium subscriptions)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
